# --- Server ---
APP_NAME=transportation-api
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- External data sources (Hong Kong open data) ---
KMB_BASE_URL=https://data.etabus.gov.hk/v1/transport/kmb
CITYBUS_BASE_URL=https://rt.data.gov.hk/v2/transport/citybus
HKO_BASE_URL=https://data.weather.gov.hk/weatherAPI/opendata/weather.php
TD_BASE_URL=https://www.td.gov.hk/{lang}/special_news/trafficnews.xml

# --- Request behavior ---
REQUEST_TIMEOUT=10
DEFAULT_LANG=tc
USER_AGENT=transportation-api/0.2 (+local)

# --- Upstream API authentication (optional, keyed tier) ---
# The HK open-data feeds are public and need no key today. Set these only if
# you move to a keyed tier (e.g. api.data.gov). Leave blank to call anonymously.
# KMB_API_KEY=
# CITYBUS_API_KEY=
# HKO_API_KEY=
# TD_API_KEY=
# Header/scheme for the key:
#   Authorization: Bearer <key>  (default)
#   X-Api-Key: <key>             -> API_AUTH_HEADER=X-Api-Key API_AUTH_SCHEME=
# API_AUTH_HEADER=Authorization
# API_AUTH_SCHEME=Bearer

# --- Outbound rate limiting (requests/second per provider) ---
# Paces our own calls so we never flood a shared public feed.
RATE_LIMIT_KMB=20
RATE_LIMIT_CITYBUS=20
RATE_LIMIT_HKO=10
RATE_LIMIT_TD=5
RATE_LIMIT_BURST=10

# --- Retry / backoff on transient upstream failures ---
MAX_RETRIES=3
RETRY_BACKOFF_BASE=0.25
RETRY_BACKOFF_MAX=4.0

# --- Caching (in-memory TTL, seconds) ---
CACHE_TTL=30
CACHE_TTL_ETA=10
CACHE_TTL_WEATHER=30
CACHE_TTL_WEATHER_API=600
CACHE_TTL_INCIDENTS=120

# --- Resilience / offline ---
# When true (default), the combined endpoint degrades gracefully on an upstream
# error (partial data, HTTP 200) instead of returning 5xx.
DEGRADE_ON_UPSTREAM_ERROR=true
# When true, serve built-in mock data and bypass all live providers.
USE_MOCK_DATA=false
